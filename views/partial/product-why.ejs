<section class="mb-4">
  <div class="container card">
    <div class="row align-items-center">

      <div class="col-md-6 text-center">
        <img src="<%= data.image %>" class="img-fluid" alt="product">
      </div>

      <div class="col-md-6">
        <h1 class="text-center">
          <%= data.title %>
        </h1>
        <p class="lead text-center">
          <%= data.subtitle %>
        </p>

        <ul>
          <% data.points.forEach(element=> {%>
            <li>
              <h5>
                <%= element.title %>
              </h5>
              <p>
                <%= element.description %>
              </p>
            </li>
            <%}); %>

        </ul>
      </div>


    </div>
  </div>
</section>