<section >
  <div class="container text-center mb-4 pb-4 pt-4 bg-white">
    <h2 class="mb-4 fw-semibold">Resources</h2>

    <div class="row">
      <% data.forEach(element => {%>
          <div class="col-md-3">
        <div class="card">
          <div class="card-body">
            <h5><%= element.title %></h5>
            <a class="btn btn-primary btn-sm" href="<%= element.link %>"><%= element.buttonText %></a>
          </div>
        </div>
      </div>
     <% }); %>
    </div>
  </div>
</section>


