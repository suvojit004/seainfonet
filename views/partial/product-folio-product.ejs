<section class="mb-4">
  <div class="container  bg-white">
    <h2 class="text-center mb-4 pt-4 fw-semibold">Products</h2>

    <div class="row text-center pb-4">

      <% data.forEach(element => { %>
        <div class="col-md-3">
        <div class="card custom-hover">
          <div class="card-body">
            <h5><%= element.title %></h5>
            <p ><%= element.description %></p>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>