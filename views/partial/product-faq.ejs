<section class="mb-4">
  <div class="container bg-white">
    <h2 class="text-center mb-4 fw-semibold pt-2">FAQs</h2>

    <div class="accordion accordion-flush" id="product-faq">
      <% data.forEach((element, index)=> { %>
        <div class="accordion-item">
          <h2 class="accordion-header">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
              data-bs-target="#faq<%= index %>" aria-expanded="false" aria-controls="faq<%= index %>">
              <%= element.question %>
            </button>
          </h2>

          <div id="faq<%= index %>" class="accordion-collapse collapse" data-bs-parent="#product-faq">
            <div class="accordion-body">
              <%= element.answer %>
            </div>
          </div>
        </div>
        <% }) %>
    </div>
</section>

